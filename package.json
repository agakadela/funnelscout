    "@vitejs/plugin-react": "^4.5.2",
    "@vitest/coverage-v8": "^4.0.6",
    "dotenv": "^16.4.7",
    "drizzle-kit": "^0.31.4",
    "eslint": "^9.28.0",
    "eslint-config-next": "16.2.3",
    "eslint-config-prettier": "^10.1.5",
    "jsdom": "^26.1.0",
    "prettier": "^3.5.3",
    "react-email": "^3.0.7",
    "tailwindcss": "^4.1.8",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3",
    "vitest": "^4.0.6"
