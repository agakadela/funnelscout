    "db:studio": "drizzle-kit studio",
    "db:seed": "tsx scripts/run-db-seed.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "@paralleldrive/cuid2": "^2.2.2",
    "@react-email/render": "1.0.5",
    "@radix-ui/react-slot": "^1.2.3",
    "@sentry/nextjs": "^9.47.0",
    "better-auth": "^1.4.7",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "drizzle-orm": "^0.41.0",
    "inngest": "^3.39.2",
    "next": "16.2.3",
    "postgres": "^3.4.5",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "resend": "^3.5.0",
    "stripe": "^17.7.0",
    "tailwind-merge": "^3.3.1",
    "zod": "^3.24.2"
