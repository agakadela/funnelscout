
DATABASE_URL=postgresql://[user]:[password]@[host]:6543/postgres?pgbouncer=true
DATABASE_URL_DIRECT=postgresql://[user]:[password]@[host]:5432/postgres

GHL_CLIENT_ID=your_ghl_client_id
GHL_CLIENT_SECRET=your_ghl_client_secret
GHL_WEBHOOK_SECRET=your_ghl_webhook_secret
GHL_REDIRECT_URI=https://example.com/api/ghl/oauth/callback

STRIPE_SECRET_KEY=sk_test_placeholder
STRIPE_WEBHOOK_SECRET=whsec_placeholder

ANTHROPIC_API_KEY=sk-ant-placeholder

RESEND_API_KEY=re_placeholder

INNGEST_EVENT_KEY=placeholder
INNGEST_SIGNING_KEY=placeholder

BETTER_AUTH_SECRET=replace_with_long_random_secret
BETTER_AUTH_URL=http://localhost:3000

# Optional — leave unset locally if you are not sending errors to Sentry.
# NEXT_PUBLIC_SENTRY_DSN=https://examplePublicKey@o0.ingest.sentry.io/0
# SENTRY_ORG=your-org
# SENTRY_PROJECT=funnelscout
# SENTRY_AUTH_TOKEN=  (optional; CI — enables source map upload during pnpm build)

# 32-byte key as 64 hex characters (AES-256-GCM). Replace — do not use placeholder in production.
GHL_TOKEN_ENCRYPTION_KEY=deadbeefdeadbeefdeadbeefdeadbeefdeadbeefdeadbeefdeadbeefdeadbeef
