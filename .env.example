# Copy to .env.local and fill in values. Never commit real secrets.
# Validated at runtime via lib/env.ts (see docs/spec.md).

# Supabase — Transaction Pooler (port 6543) for app runtime (e.g. Vercel)
DATABASE_URL=postgresql://USER:PASSWORD@HOST:6543/postgres?pgbouncer=true

# Supabase — Direct connection (port 5432). Local only: drizzle-kit migrate.
# Not loaded by lib/env.ts; drizzle.config.ts reads process.env.DATABASE_URL_DIRECT
DATABASE_URL_DIRECT=postgresql://USER:PASSWORD@HOST:5432/postgres

GHL_CLIENT_ID=
GHL_CLIENT_SECRET=
GHL_WEBHOOK_SECRET=
GHL_REDIRECT_URI=https://localhost:3000/api/ghl/oauth/callback

# 32-byte key, hex-encoded (64 characters) — AES-256-GCM for GHL tokens at rest
GHL_TOKEN_ENCRYPTION_KEY=

STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

ANTHROPIC_API_KEY=

RESEND_API_KEY=

INNGEST_EVENT_KEY=
INNGEST_SIGNING_KEY=

BETTER_AUTH_SECRET=
BETTER_AUTH_URL=http://localhost:3000
